# Copiar a `.streamlit/secrets.toml` y completar.
# Nunca commitear secrets.toml (está en .gitignore).

# --- Auth de la app ---
contabilidad_password = "REEMPLAZAR_CON_PASSWORD_FUERTE"

# --- API Contabilium UY ---
contabilium_client_id     = "email_admin@suprabond.com.uy"
contabilium_client_secret = "REEMPLAZAR_CON_API_KEY"

# --- Google Sheets ---
# El spreadsheet_id está en la URL del Sheet, entre /d/ y /edit:
#   https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
# Compartir el Sheet con el client_email del service account como Editor.
[gsheets]
spreadsheet_id = "REEMPLAZAR_CON_ID_DEL_SHEET"

# Para correr localmente, apuntar a un JSON descargado del service
# account. La ruta es relativa al repo. NO commitear ese .json.
service_account_json_path = ".gsheets/sa.json"

# Para producción (Streamlit Cloud), comentar la línea de arriba y
# descomentar este bloque, pegando el contenido del JSON.
# [gsheets.service_account]
# type = "service_account"
# project_id = "..."
# private_key_id = "..."
# private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# client_email = "...@....iam.gserviceaccount.com"
# client_id = "..."
# auth_uri = "https://accounts.google.com/o/oauth2/auth"
# token_uri = "https://oauth2.googleapis.com/token"
# auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
# client_x509_cert_url = "..."
